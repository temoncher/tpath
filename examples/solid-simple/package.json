{
  "name": "tpath-example-solid-simple",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "check": "oxfmt --check . && oxlint && tsc --noEmit --project tsconfig.json && knip",
    "dev": "vite --host 127.0.0.1",
    "build": "tsc --noEmit --project tsconfig.json && vite build",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt --write .",
    "knip": "pnpm generate:translations && knip",
    "knip:exports": "pnpm generate:translations && knip --exports",
    "fix": "oxfmt --write . && oxlint --fix",
    "test": "vitest run --config vitest.config.ts"
  },
  "dependencies": {
    "intl-messageformat": "^10.7.18",
    "solid-js": "^1.9.13"
  },
  "devDependencies": {
    "@solidjs/testing-library": "^0.8.0",
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/user-event": "^14.0.0",
    "jsdom": "^27.0.0",
    "knip": "^5.0.0",
    "oxfmt": "0.52.0",
    "oxlint": "^1.67.0",
    "typescript": "5.7.2",
    "vite": "^7.0.0",
    "vite-plugin-solid": "^2.11.12",
    "vitest": "^4.0.0"
  }
}
